{
	"name": "gnina",
	"displayName": "GNINA",
	"version": "1.3",
	"description": "CNN-based molecular docking (Apache-2.0)",
	"license": "Apache-2.0",
	"upstream": "https://github.com/gnina/gnina",
	"gpu": "rtx4090",
	"typicalRuntimeSec": 180,
	"maxRuntimeSec": 1800,
	"endpointEnv": "RUNPOD_GNINA_ENDPOINT_ID",
	"args": {
		"receptor": {
			"type": "path",
			"required": true,
			"description": "Receptor PDB file"
		},
		"ligand": {
			"type": "path",
			"required": true,
			"description": "Ligand SDF file"
		},
		"autobox": {
			"type": "path",
			"required": false,
			"description": "Reference ligand for autobox (defaults to ligand)"
		},
		"exhaustiveness": {
			"type": "number",
			"required": false,
			"default": 8,
			"description": "Search exhaustiveness"
		},
		"num-modes": {
			"type": "number",
			"required": false,
			"default": 9,
			"description": "Number of binding modes to output"
		},
		"seed": {
			"type": "number",
			"required": false,
			"description": "Random seed for reproducibility"
		}
	}
}

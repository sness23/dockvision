# DockVision environment template. Copy to .env (local dev) or
# /etc/dockvision/env (www0). Never commit a real .env.

# --- core ---
NODE_ENV=development
PORT=3000
ORIGIN=https://dockvision.doi.bio   # set to http://localhost:3000 for dev

# --- Postgres ---
DATABASE_URL=postgres://dockvision:CHANGE_ME@localhost:5432/dockvision

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=CHANGE_ME_OPENSSL_RAND_BASE64_32
AUTH_TRUST_HOST=true                # required when behind nginx

# --- email (magic-link sign-in) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=DockVision <no-reply@dockvision.doi.bio>

# --- OAuth (optional in Phase 0) ---
# Get from https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Get from https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- AWS S3 (Phase 1+) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=dockvision-prod

# --- Stripe (Phase 1+) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# --- RunPod (Phase 1+) ---
RUNPOD_API_KEY=
RUNPOD_GNINA_ENDPOINT_ID=
RUNPOD_BOLTZ2_ENDPOINT_ID=
RUNPOD_PROTENIX_ENDPOINT_ID=

# --- pricing config ---
MARKUP_MULTIPLIER=1.5
STORAGE_FREE_GB=5
STORAGE_PRICE_CENTS_PER_GB_MONTH=4
TOPUP_MIN_CENTS=1000

{
  "name": "dockvision",
  "version": "0.0.1",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "description": "Open-source CLI-shaped web platform for protein-ligand docking on serverless GPUs",
  "homepage": "https://dockvision.doi.bio",
  "repository": {
    "type": "git",
    "url": "https://github.com/sness23/dockvision.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node build/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "node scripts/migrate.mjs up",
    "migrate:status": "node scripts/migrate.mjs status"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.2.9",
    "@sveltejs/kit": "^2.8.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/nodemailer": "^7.0.2",
    "@types/pg": "^8.11.10",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.7",
    "svelte": "^5.1.9",
    "svelte-check": "^4.0.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.2",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "@auth/pg-adapter": "^1.7.4",
    "@auth/sveltekit": "^1.7.4",
    "nodemailer": "^7.0.7",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=20"
  }
}
